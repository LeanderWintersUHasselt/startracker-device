#!/usr/bin/env bash
set -euo pipefail

# Only auto-start tracking when booting headless (no HDMI display connected).
# When a display is present, the UI controls tracking manually.
for status in /sys/class/drm/card1-HDMI-A-*/status; do
    if [[ -r "$status" ]] && grep -qs "^connected$" "$status"; then
        exit 0
    fi
done

SOCK_PATH="/run/startracker/startracker.sock"

for _ in $(seq 1 100); do
    [[ -S "$SOCK_PATH" ]] && break
    sleep 0.1
done

[[ -S "$SOCK_PATH" ]] || exit 0

python3 - <<'PY'
import json
import os
import socket
import time

sock_path = "/run/startracker/startracker.sock"
deadline = time.time() + 5.0

while time.time() < deadline:
    if not os.path.exists(sock_path):
        time.sleep(0.1)
        continue

    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.settimeout(2.0)
        sock.connect(sock_path)
        sock.sendall((json.dumps({"cmd": "start_track"}) + "\n").encode())
        try:
            sock.recv(4096)
        except OSError:
            pass
        sock.close()
        break
    except OSError:
        time.sleep(0.1)
PY
